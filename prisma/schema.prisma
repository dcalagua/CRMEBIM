generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Rol {
  admin
  ejecutiva
}

enum PaisEjecutiva {
  PE
  EC
}

enum EstadoLead {
  nuevo
  asignado
  contactado
  respondio
  agendado
  calificado
  descartado
}

enum OrigenLead {
  lusha
  manual
  csv
}

enum TipoActividad {
  asignacion
  whatsapp_abierto
  cambio_estado
  nota
  oportunidad
  reunion
}

enum EtapaOportunidad {
  creada
  propuesta_enviada
  negociacion
  cerrada_ganada
  cerrada_perdida
}

model User {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String   @map("password_hash")
  rol          Rol
  pais         PaisEjecutiva?
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  leadsAsignados        Lead[]        @relation("LeadAsignadaA")
  actividades           Actividad[]
  agenteRuns            AgenteRun[]
  oportunidadesAsignadas Oportunidad[]

  @@map("users")
}

model Empresa {
  id              String   @id @default(cuid())
  nombre          String
  sitioWeb        String?  @map("sitio_web")
  linkedinEmpresa String?  @map("linkedin_empresa")
  tecnologias     String[] @default([])
  resumen         String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  leads Lead[]

  @@index([nombre])
  @@map("empresas")
}

model Lead {
  id               String     @id @default(cuid())
  empresa          String
  empresaId        String?    @map("empresa_id")
  empresaRel       Empresa?   @relation(fields: [empresaId], references: [id])
  contactoNombre   String?    @map("contacto_nombre")
  contactoApellido String?    @map("contacto_apellido")
  cargo            String?
  nivelDecision    String?    @map("nivel_decision")
  telefono         String
  email            String?
  linkedinContacto String?    @map("linkedin_contacto")
  sector           String?
  tamanoEmpresa    String?    @map("tamano_empresa")
  ciudad           String?
  departamento     String?
  origen           OrigenLead @default(manual)
  lushaId          String?    @map("lusha_id")
  segmento         String?
  estado           EstadoLead @default(nuevo)
  asignadaAId      String?    @map("asignada_a_id")
  asignadaA        User?      @relation("LeadAsignadaA", fields: [asignadaAId], references: [id])
  reunionFecha       DateTime? @map("reunion_fecha")
  reunionNotas       String?   @map("reunion_notas")
  proximaAccionFecha DateTime? @map("proxima_accion_fecha")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  actividades   Actividad[]
  oportunidades Oportunidad[]

  @@index([asignadaAId])
  @@index([estado])
  @@index([empresaId])
  @@map("leads")
}

model Oportunidad {
  id                  String           @id @default(cuid())
  leadId              String           @map("lead_id")
  lead                Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  asignadaAId         String           @map("asignada_a_id")
  asignadaA           User             @relation(fields: [asignadaAId], references: [id])
  etapa               EtapaOportunidad @default(creada)
  valorEstimado       Decimal?         @map("valor_estimado") @db.Decimal(12, 2)
  moneda              String           @default("USD")
  fechaCierreEstimada DateTime?        @map("fecha_cierre_estimada")
  motivoPerdida       String?          @map("motivo_perdida")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  cerradaEn           DateTime?        @map("cerrada_en")

  @@index([leadId])
  @@index([asignadaAId])
  @@index([etapa])
  @@map("oportunidades")
}

model Actividad {
  id        String        @id @default(cuid())
  leadId    String        @map("lead_id")
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id])
  tipo      TipoActividad
  detalle   String?
  timestamp DateTime      @default(now())

  @@index([leadId])
  @@index([userId])
  @@map("actividades")
}

model AgenteRun {
  id            String   @id @default(cuid())
  ejecutadoPorId String  @map("ejecutado_por_id")
  ejecutadoPor  User     @relation(fields: [ejecutadoPorId], references: [id])
  fecha         DateTime @default(now())
  filtrosUsados Json     @map("filtros_usados")
  leadsTraidos  Int      @map("leads_traidos")
  leadsNuevos   Int      @map("leads_nuevos")

  @@map("agente_runs")
}

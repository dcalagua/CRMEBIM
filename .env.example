# Supabase Postgres (Project Settings > Database > Connection string)
# Usar el pooler (puerto 6543) para DATABASE_URL y la conexion directa (puerto 5432) para DIRECT_URL (migraciones)
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:5432/postgres"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="reemplazar-con-un-valor-aleatorio-largo"

# Password inicial para el seed de usuarios (admin + ejecutivas) - reemplazar por una propia, no usar un valor real acá
SEED_DEFAULT_PASSWORD="reemplazar-con-tu-propia-password-temporal"

# Lusha Prospecting API (docs.lusha.com)
LUSHA_API_KEY="reemplazar-con-tu-api-key-de-lusha"
